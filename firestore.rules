rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /shares/{shareId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly([
          'groupName',
          'name',
          'content',
          'createdAt',
          'dateKey'
        ])
        && request.resource.data.groupName is string
        && request.resource.data.groupName.size() > 0
        && request.resource.data.groupName.size() <= 40
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 40
        && request.resource.data.content is string
        && request.resource.data.content.size() > 0
        && request.resource.data.content.size() <= 1000
        && request.resource.data.dateKey is string
        && request.resource.data.dateKey.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /draws/{drawId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly([
          'shareId',
          'dateKey',
          'drawnAt'
        ])
        && request.resource.data.shareId is string
        && request.resource.data.shareId.size() > 0
        && request.resource.data.dateKey is string
        && request.resource.data.dateKey.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && request.resource.data.drawnAt == request.time;
      allow update, delete: if false;
    }
  }
}
